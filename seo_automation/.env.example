# ────────────────────────────────────────────────────────────
# SEO/AEO Content Automation — Environment Configuration
# ────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# ────────────────────────────────────────────────────────────

# ── OpenAI (LLM tasks) ─────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=4096

# ── Gemini (image generation only) ─────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ── WordPress ───────────────────────────────────────────────
WP_URL=https://your-wordpress-site.com
WP_USERNAME=your-wp-username
WP_APP_PASSWORD=your-wp-application-password
WP_PUBLISH_STATUS=draft

# ── Database ────────────────────────────────────────────────
DB_PATH=seo_automation.db

# ── Google Trends ───────────────────────────────────────────
TRENDS_REGION=india
TRENDS_LANGUAGE=en-IN

# ── Reddit (optional, for fetching from subreddits) ─────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=SEOBot/1.0

# ── Article Settings ────────────────────────────────────────
MIN_WORD_COUNT=1500
MAX_WORD_COUNT=2000
ARTICLES_PER_DAY=10

# ── Internal Linking ────────────────────────────────────────
RELATED_LINKS_COUNT=3
PILLAR_LINKS_COUNT=1
